<launch>

    <include file="$(find iai_tiago_description)/launch/upload.launch"/>

    <node pkg="giskardpy_ros" type="tiago_standalone.py" name="giskard" output="screen"/>

    <node pkg="giskardpy_ros" type="interactive_marker.py" name="giskard_interactive_marker" output="screen">
        <rosparam param="enable_self_collision">False</rosparam>
        <rosparam param="interactive_marker_chains">
            - [base_footprint, gripper_left_grasping_frame]
            - [base_footprint, gripper_right_grasping_frame]
            - [base_footprint, xtion_link]
            - [map, base_footprint]
        </rosparam>
    </node>

    <node name="rviz" pkg="rviz" type="rviz" args="-d $(find giskardpy_ros)/launch/rviz_config/standalone.rviz"/>

</launch>
